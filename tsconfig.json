{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "lib":  [
                                        "dom",
                                        "dom.iterable",
                                        "es2022"
                                    ],
                            "allowJs":  false,
                            "skipLibCheck":  true,
                            "strict":  true,
                            "noEmit":  true,
                            "esModuleInterop":  true,
                            "module":  "esnext",
                            "moduleResolution":  "bundler",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "jsx":  "preserve",
                            "incremental":  true,
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ],
                            "paths":  {
                                          "@web/*":  [
                                                         "./apps/web/*"
                                                     ],
                                          "@warsneaks/domain":  [
                                                                    "./packages/domain/src/index.ts"
                                                                ],
                                          "@warsneaks/shared":  [
                                                                    "./packages/shared/src/index.ts"
                                                                ],
                                          "@warsneaks/db":  [
                                                                "./packages/db/src/index.ts"
                                                            ]
                                      },
                            "allowImportingTsExtensions":  true
                        },
    "include":  [
                    "next-env.d.ts",
                    "apps/**/*.ts",
                    "apps/**/*.tsx",
                    "packages/**/*.ts",
                    "tests/**/*.ts",
                    ".next/types/**/*.ts"
                ],
    "exclude":  [
                    "node_modules"
                ]
}